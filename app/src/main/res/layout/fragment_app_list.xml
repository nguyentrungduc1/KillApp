<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:hint="@string/search_hint"
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:text="Tất cả"
            android:textColor="@color/cyan_primary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="12dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- App type filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Tất cả"
                android:textColor="@color/bg_dark"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_kill_button"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipUser"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Người dùng"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chipSystem"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Hệ thống"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_card"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

</LinearLayout>
