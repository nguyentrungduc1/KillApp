<?xml version="1.0" encoding="utf-8"?>
<!-- Popup tiến trình — hiện tự động khi kill đang chạy, ẩn khi xong -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatRoot"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_popup"
    android:elevation="12dp"
    android:clipToOutline="true">

    <!-- Thanh tiến trình full-width trên cùng -->
    <ProgressBar
        android:id="@+id/floatProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progressDrawable="@drawable/progress_bar"
        android:max="100"
        android:progress="0" />

    <!-- Nội dung popup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- Tên bước hiện tại: "Xoá cache" / "Buộc dừng" / "Đóng Recents" -->
        <TextView
            android:id="@+id/floatStepName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang xử lý…"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Dòng phụ: "#N, chờ…" -->
        <TextView
            android:id="@+id/floatStepSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <!-- Counter + tên app: "31 / 48   Android Auto" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/floatCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 0"
                android:textColor="@color/cyan_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/floatAppName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
